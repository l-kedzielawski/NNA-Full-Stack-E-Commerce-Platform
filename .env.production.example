# Production environment variables
# Copy to .env.production on the VPS, then fill in every value.
# NEVER commit .env.production to git.
#
# Generate random secrets with:
#   openssl rand -base64 48
# Generate APP_KEYS (4 comma-separated base64 values):
#   echo "$(openssl rand -base64 32),$(openssl rand -base64 32),$(openssl rand -base64 32),$(openssl rand -base64 32)"

# ─── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=themysticaroma.com

# Shared-proxy localhost ports (used by docker-compose.prod.shared-proxy.yml)
NEXTJS_HOST_PORT=3100
MEDUSA_HOST_PORT=9100
STRAPI_HOST_PORT=1437

# Traefik mode (used by docker-compose.prod.traefik.yml)
TRAEFIK_PUBLIC_NETWORK=traefik-public
TRAEFIK_CERTRESOLVER=letsencrypt

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=mystic
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Medusa backend ───────────────────────────────────────────────────────────
MEDUSA_JWT_SECRET=CHANGE_ME_openssl_rand_base64_48
MEDUSA_COOKIE_SECRET=CHANGE_ME_openssl_rand_base64_48

MEDUSA_BACKEND_URL=https://api.themysticaroma.com
STORE_CORS=https://themysticaroma.com,https://www.themysticaroma.com
ADMIN_CORS=https://admin.themysticaroma.com
AUTH_CORS=https://themysticaroma.com,https://www.themysticaroma.com

STRIPE_API_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_CAPTURE=true
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=noreply@themysticaroma.com
EMAIL_REPLY_TO=orders@themysticaroma.com
ORDER_NOTIFY_EMAILS=orders@themysticaroma.com
LEAD_NOTIFY_EMAILS=l.kedzielawski@themysticaroma.com

# ─── Strapi CMS ───────────────────────────────────────────────────────────────
# Each APP_KEYS entry must be unique base64 strings
STRAPI_APP_KEYS=CHANGE_ME_key1,CHANGE_ME_key2,CHANGE_ME_key3,CHANGE_ME_key4
STRAPI_API_TOKEN_SALT=CHANGE_ME_openssl_rand_base64_48
STRAPI_ADMIN_JWT_SECRET=CHANGE_ME_openssl_rand_base64_48
STRAPI_TRANSFER_TOKEN_SALT=CHANGE_ME_openssl_rand_base64_48
STRAPI_JWT_SECRET=CHANGE_ME_openssl_rand_base64_48

# ─── Next.js frontend ─────────────────────────────────────────────────────────
# Medusa publishable API key — used server-side by the /api/medusa proxy.
# Get it from Medusa admin → Settings → API Keys.
MEDUSA_PUBLISHABLE_KEY=pk_CHANGE_ME

# NEXT_PUBLIC_MEDUSA_URL is only used for server-side SSG product fetching.
# In production Docker, this points to the internal service name (not the public domain).
# The browser never calls this URL directly — it goes through /api/medusa proxy.
# This value is hard-coded to http://medusa:9000 in docker-compose.prod.yml.
# Only override here if your Medusa container name differs.
# NEXT_PUBLIC_MEDUSA_URL=http://medusa:9000

NEXT_PUBLIC_MEDUSA_REGION_ID=reg_01KJHP86BNMGJ6AMCAMVE86J82
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-CHANGE_ME

PRODUCTS_SOURCE=medusa
QUOTE_NOTIFY_EMAILS=orders@themysticaroma.com,l.kedzielawski@themysticaroma.com
QUOTE_LOCAL_BACKUP_ENABLED=false
