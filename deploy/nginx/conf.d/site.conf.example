# Example in-stack nginx vhost for dedicated VPS mode.
# Copy to `deploy/nginx/conf.d/site.conf` and adjust domains/cert paths.

server {
    listen 80;
    server_name example.com www.example.com api.example.com admin.example.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name example.com www.example.com;
    http2 on;

    ssl_certificate     /etc/letsencrypt/live/example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/example.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    if ($host = www.example.com) {
        return 301 https://example.com$request_uri;
    }

    location /_next/static/ {
        proxy_pass http://nextjs:3000;
        proxy_cache_valid 200 365d;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location /public/ {
        proxy_pass http://nextjs:3000;
        add_header Cache-Control "public, max-age=86400";
    }

    location / {
        proxy_pass http://nextjs:3000;
    }
}

server {
    listen 443 ssl;
    server_name api.example.com;
    http2 on;

    ssl_certificate     /etc/letsencrypt/live/example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/example.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    location /static/ {
        proxy_pass http://medusa:9000;
        add_header Cache-Control "public, max-age=86400";
    }

    location / {
        proxy_pass         http://medusa:9000;
        proxy_read_timeout 120s;
        client_max_body_size 50m;
    }
}

server {
    listen 443 ssl;
    server_name admin.example.com;
    http2 on;

    ssl_certificate     /etc/letsencrypt/live/example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/example.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass         http://strapi:1337;
        proxy_read_timeout 120s;
        client_max_body_size 50m;
    }
}
