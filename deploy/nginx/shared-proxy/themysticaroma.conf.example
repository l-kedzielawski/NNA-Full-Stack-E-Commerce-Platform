# Example host-level nginx vhost for shared proxy mode.
# Copy into your shared nginx (outside this app stack) and adjust cert paths.

server {
    listen 80;
    server_name themysticaroma.com www.themysticaroma.com api.themysticaroma.com admin.themysticaroma.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name themysticaroma.com www.themysticaroma.com;

    ssl_certificate     /etc/letsencrypt/live/themysticaroma.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/themysticaroma.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    if ($host = www.themysticaroma.com) {
        return 301 https://themysticaroma.com$request_uri;
    }

    location / {
        proxy_pass http://127.0.0.1:3100;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

server {
    listen 443 ssl http2;
    server_name api.themysticaroma.com;

    ssl_certificate     /etc/letsencrypt/live/themysticaroma.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/themysticaroma.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://127.0.0.1:9100;
        proxy_read_timeout 120s;
        client_max_body_size 50m;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

server {
    listen 443 ssl http2;
    server_name admin.themysticaroma.com;

    ssl_certificate     /etc/letsencrypt/live/themysticaroma.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/themysticaroma.com/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://127.0.0.1:1437;
        proxy_read_timeout 120s;
        client_max_body_size 50m;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
