NEXT_PUBLIC_SITE_URL=https://www.themysticaroma.com

# Locale and routing
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Medusa commerce backend
NEXT_PUBLIC_MEDUSA_URL=http://localhost:9000
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_replace_me
NEXT_PUBLIC_MEDUSA_REGION_ID=reg_replace_me

# Stripe (frontend/public key only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Analytics (GA4)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Email (server-side)
RESEND_API_KEY=

# Quote backup storage (local JSONL fallback)
# true in local development, false on production VPS
QUOTE_LOCAL_BACKUP_ENABLED=true

# Docker Compose infrastructure credentials
# Generate strong passwords with: openssl rand -base64 32
POSTGRES_USER=mystic
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# Optional runtime content override
# CONTENT_DIR=/absolute/path/to/content
# PRODUCTS_FILE=products.from-csv.json
# PRODUCTS_SOURCE=file
# PRODUCTS_SOURCE=medusa
